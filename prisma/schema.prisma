generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SourceCategory {
  SELL_SIDE
  INDEPENDENT
  AGGREGATOR
}

enum NormalizedRating {
  STRONG_BUY
  BUY
  HOLD
  SELL
  STRONG_SELL
}

enum RatingActionType {
  INITIATED
  UPGRADED
  DOWNGRADED
  MAINTAINED
  REITERATED
  RESUMED
}

enum AlertType {
  PRICE_ABOVE
  PRICE_BELOW
  RATING_CHANGE
  PRICE_TARGET_CHANGE
  NEWS_SENTIMENT
  VOLUME_SPIKE
  EARNINGS_DATE
}

model User {
  id           String      @id @default(cuid())
  email        String      @unique
  passwordHash String?
  authProvider String?
  portfolios   Portfolio[]
  watchlists   Watchlist[]
  alerts       Alert[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Portfolio {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  baseCurrency String    @default("USD")
  holdings     Holding[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Holding {
  id          String    @id @default(cuid())
  portfolioId String
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  ticker      String
  companyName String?
  quantity    Decimal   @db.Decimal(18, 6)
  averageCost Decimal   @db.Decimal(18, 6)
  purchaseDate DateTime?
  notes       String?
  strategyTag String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([portfolioId])
  @@index([ticker])
}

model Stock {
  ticker      String   @id
  companyName String
  exchange    String?
  sector      String?
  industry    String?
  country     String?
  currency    String?
  marketCap   Decimal? @db.Decimal(24, 2)
  cik         String?
  figi        String?
  isin        String?
  updatedAt   DateTime @updatedAt
}

model Quote {
  id            String   @id @default(cuid())
  ticker        String
  price         Decimal  @db.Decimal(18, 6)
  previousClose Decimal? @db.Decimal(18, 6)
  open          Decimal? @db.Decimal(18, 6)
  high          Decimal? @db.Decimal(18, 6)
  low           Decimal? @db.Decimal(18, 6)
  volume        BigInt?
  change        Decimal? @db.Decimal(18, 6)
  changePercent Decimal? @db.Decimal(12, 6)
  timestamp     DateTime
  provider      String

  @@index([ticker, timestamp])
}

model HistoricalPrice {
  id            String   @id @default(cuid())
  ticker        String
  date          DateTime
  open          Decimal  @db.Decimal(18, 6)
  high          Decimal  @db.Decimal(18, 6)
  low           Decimal  @db.Decimal(18, 6)
  close         Decimal  @db.Decimal(18, 6)
  adjustedClose Decimal? @db.Decimal(18, 6)
  volume        BigInt
  provider      String

  @@unique([ticker, date, provider])
}

model AnalystFirm {
  id          String          @id @default(cuid())
  name        String          @unique
  category    SourceCategory
  description String?
  website     String?
  ratings     AnalystRating[]
  createdAt   DateTime        @default(now())
}

model AnalystRating {
  id                  String           @id @default(cuid())
  ticker              String
  firmId              String
  firm                AnalystFirm      @relation(fields: [firmId], references: [id])
  analystName         String?
  actionType          RatingActionType
  originalRating      String
  normalizedRating    NormalizedRating
  previousRating      String?
  priceTarget         Decimal?         @db.Decimal(18, 6)
  previousPriceTarget Decimal?         @db.Decimal(18, 6)
  currency            String?
  ratingDate          DateTime
  sourceProvider      String
  sourceUrl           String?
  confidenceScore     Decimal?         @db.Decimal(5, 4)
  createdAt           DateTime         @default(now())

  @@index([ticker, ratingDate])
  @@index([firmId])
}

model ConsensusRating {
  id                 String           @id @default(cuid())
  ticker             String
  strongBuyCount     Int
  buyCount           Int
  holdCount          Int
  sellCount          Int
  strongSellCount    Int
  consensusLabel     NormalizedRating
  averagePriceTarget Decimal?         @db.Decimal(18, 6)
  medianPriceTarget  Decimal?         @db.Decimal(18, 6)
  highPriceTarget    Decimal?         @db.Decimal(18, 6)
  lowPriceTarget     Decimal?         @db.Decimal(18, 6)
  numberOfAnalysts   Int
  upsidePercent      Decimal?         @db.Decimal(12, 6)
  asOfDate           DateTime
  provider           String

  @@index([ticker, asOfDate])
}

model Fundamentals {
  id              String   @id @default(cuid())
  ticker          String
  revenue         Decimal? @db.Decimal(24, 2)
  grossMargin     Decimal? @db.Decimal(12, 6)
  operatingMargin Decimal? @db.Decimal(12, 6)
  netIncome       Decimal? @db.Decimal(24, 2)
  eps             Decimal? @db.Decimal(18, 6)
  peRatio         Decimal? @db.Decimal(18, 6)
  forwardPe       Decimal? @db.Decimal(18, 6)
  pegRatio        Decimal? @db.Decimal(18, 6)
  priceToSales    Decimal? @db.Decimal(18, 6)
  priceToBook     Decimal? @db.Decimal(18, 6)
  debtToEquity    Decimal? @db.Decimal(18, 6)
  freeCashFlow    Decimal? @db.Decimal(24, 2)
  dividendYield   Decimal? @db.Decimal(12, 6)
  fiscalPeriod    String?
  fiscalYear      Int?
  provider        String

  @@index([ticker, fiscalYear, fiscalPeriod])
}

model NewsItem {
  id          String   @id @default(cuid())
  ticker      String
  title       String
  summary     String?
  url         String
  source      String
  sentiment   String?
  publishedAt DateTime
  provider    String

  @@index([ticker, publishedAt])
}

model Watchlist {
  id        String          @id @default(cuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  items     WatchlistItem[]
  createdAt DateTime        @default(now())
}

model WatchlistItem {
  id          String    @id @default(cuid())
  watchlistId String
  watchlist   Watchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)
  ticker      String
  notes       String?
  createdAt   DateTime  @default(now())

  @@unique([watchlistId, ticker])
}

model Alert {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  ticker    String
  type      AlertType
  threshold String?
  enabled   Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId, ticker])
}
